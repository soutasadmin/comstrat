---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Reveal from '../components/Reveal.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { site, url } from '../data/site';

const stats = [
  { value: '7', label: 'Sourcing countries' },
  { value: '3', label: 'Core product lines' },
  { value: '100%', label: 'Quality-checked supply' },
  { value: '24h', label: 'Typical quote response' },
];

const products = [
  {
    icon: 'battery',
    title: 'SLI Batteries',
    text: 'Starting, Lighting & Ignition batteries for passenger cars and commercial vehicles — a full range of capacities and terminal layouts.',
  },
  {
    icon: 'droplet',
    title: 'Lubricants',
    text: 'Engine oils, transmission and specialty lubricants formulated to OEM specifications for European fleets and workshops.',
  },
  {
    icon: 'gear',
    title: 'Spare Parts',
    text: 'A growing catalogue of automotive consumables and replacement parts, sourced to match demand across our markets.',
  },
];

const values = [
  { icon: 'globe', title: 'Global sourcing network', text: 'Direct relationships with manufacturers across Asia and Europe let us match the right factory to every requirement.' },
  { icon: 'shield', title: 'Quality assurance', text: 'Every product line is vetted for specification, certification and consistency before it reaches your market.' },
  { icon: 'tag', title: 'Competitive pricing', text: 'Buying at scale and close to the source, we secure prices that keep your offer sharp and your margins healthy.' },
  { icon: 'truck', title: 'Reliable logistics', text: 'Coordinated shipping from origin to destination, with documentation handled and timelines you can plan around.' },
];

const steps = [
  { n: '01', title: 'Source', text: 'We identify the manufacturer and grade that fit your specification, volume and budget.' },
  { n: '02', title: 'Verify', text: 'Specifications, certifications and samples are checked before any order is confirmed.' },
  { n: '03', title: 'Ship', text: 'We consolidate, document and dispatch — managing freight from origin to your door.' },
  { n: '04', title: 'Support', text: 'Ongoing supply, repeat orders and responsive after-sales communication.' },
];
---
<Layout>
  <!-- HERO -->
  <Hero>
    <div class="mx-auto max-w-3xl text-center">
      <Reveal>
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-medium text-slatey-200">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          Hong Kong · Sourcing worldwide · Serving Europe
        </span>
      </Reveal>
      <Reveal delay={80}>
        <h1 class="mt-6 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-6xl">
          Powering Europe's roads,
          <span class="bg-gradient-to-r from-brand-300 to-brand-500 bg-clip-text text-transparent"> sourced worldwide.</span>
        </h1>
      </Reveal>
      <Reveal delay={160}>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slatey-300">
          {site.name} supplies automotive SLI batteries, lubricants and spare parts to European
          markets — connecting trusted manufacturers across Asia and Europe with the buyers who
          depend on quality and price.
        </p>
      </Reveal>
      <Reveal delay={240}>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={url('/products')} class="btn-primary">Explore products <Icon name="arrow" class="h-4 w-4" /></a>
          <a href={url('/contact')} class="btn-ghost-light">Get in touch</a>
        </div>
      </Reveal>
    </div>
  </Hero>

  <!-- STATS STRIP -->
  <section class="relative z-10 bg-white">
    <div class="container-x">
      <Reveal class="-mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-3xl bg-slatey-200 shadow-card lg:grid-cols-4">
        {stats.map((s) => (
          <div class="bg-white p-7 text-center">
            <div class="font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{s.value}</div>
            <div class="mt-1 text-sm font-medium text-slatey-500">{s.label}</div>
          </div>
        ))}
      </Reveal>
    </div>
  </section>

  <!-- PRODUCT CATEGORIES -->
  <section class="bg-white py-20 sm:py-28">
    <div class="container-x">
      <Reveal>
        <SectionHeading
          eyebrow="What we supply"
          title="Three product lines, one trusted supplier"
          intro="From the battery that turns the key to the lubricants and parts that keep vehicles running — we source it, vet it and deliver it."
        />
      </Reveal>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {products.map((p, i) => (
          <Reveal delay={i * 90} class="group flex h-full flex-col rounded-3xl border border-slatey-200 bg-white p-8 shadow-card transition-all duration-300 hover:-translate-y-1 hover:border-brand-200 hover:shadow-card-hover">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600 ring-1 ring-brand-100 transition-colors group-hover:bg-brand-500 group-hover:text-white">
              <Icon name={p.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-6 font-display text-xl font-bold text-ink-900">{p.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-slatey-600">{p.text}</p>
            <a href={url('/products')} class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 transition-colors group-hover:gap-2.5">
              Learn more <Icon name="arrow" class="h-4 w-4" />
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY COMSTRAT -->
  <section class="bg-slatey-50 py-20 sm:py-28">
    <div class="container-x">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <Reveal>
            <SectionHeading
              eyebrow="Why Comstrat"
              title="A sourcing partner built around trust"
              intro="We sit between the factory and your market, taking on the complexity of global procurement so you receive quality products at the right price — on time."
              align="left"
            />
            <a href={url('/about')} class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:gap-3 transition-all">
              More about us <Icon name="arrow" class="h-4 w-4" />
            </a>
          </Reveal>
        </div>
        <div class="lg:col-span-7">
          <div class="grid gap-5 sm:grid-cols-2">
            {values.map((v, i) => (
              <Reveal delay={i * 70} class="rounded-2xl border border-slatey-200 bg-white p-6 shadow-card">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-ink-900 text-brand-400">
                  <Icon name={v.icon} class="h-5 w-5" />
                </span>
                <h3 class="mt-5 font-display text-base font-bold text-ink-900">{v.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slatey-600">{v.text}</p>
              </Reveal>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GLOBAL SOURCING -->
  <section class="relative overflow-hidden bg-ink-900 py-20 sm:py-28">
    <div class="pointer-events-none absolute inset-0 bg-grid-dark [background-size:56px_56px] opacity-50"></div>
    <div class="pointer-events-none absolute -left-32 top-1/2 h-96 w-96 -translate-y-1/2 rounded-full bg-brand-500/15 blur-[120px]"></div>
    <div class="container-x relative">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <Reveal>
          <SectionHeading
            eyebrow="Global reach"
            title="Manufacturers across Asia and Europe"
            intro="Our network spans established battery, lubricant and parts producers — giving us the flexibility to source the right product for every specification and budget."
            align="left"
            dark
          />
        </Reveal>
        <Reveal delay={120}>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {site.sourcing.map((c) => (
              <div class="flex items-center gap-2.5 rounded-xl border border-white/10 bg-white/5 px-4 py-3.5 backdrop-blur">
                <Icon name="pin" class="h-4 w-4 text-brand-400" />
                <span class="text-sm font-medium text-white">{c}</span>
              </div>
            ))}
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-white py-20 sm:py-28">
    <div class="container-x">
      <Reveal>
        <SectionHeading
          eyebrow="How we work"
          title="From enquiry to delivery"
          intro="A clear, four-step process that keeps procurement simple and predictable."
        />
      </Reveal>
      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (
          <Reveal delay={i * 80} class="relative rounded-3xl border border-slatey-200 bg-slatey-50 p-7">
            <span class="font-display text-4xl font-extrabold text-brand-500/30">{s.n}</span>
            <h3 class="mt-3 font-display text-lg font-bold text-ink-900">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slatey-600">{s.text}</p>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
