---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Reveal from '../components/Reveal.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';

const categories = [
  {
    id: 'batteries',
    icon: 'battery',
    title: 'SLI Batteries',
    lead: 'Starting, Lighting & Ignition batteries for passenger and commercial vehicles.',
    body: 'The SLI battery is the heart of every vehicle start. We supply a comprehensive range of lead-acid and maintenance-free batteries — across capacities, terminal layouts and case sizes — to fit the European vehicle parc. Sourced from established manufacturers and checked for specification and consistency before shipment.',
    features: [
      'Passenger car & commercial vehicle ranges',
      'Standard, low-maintenance & maintenance-free types',
      'Wide span of capacities (Ah) and cold-cranking ratings',
      'Specification and certification verified per order',
    ],
  },
  {
    id: 'lubricants',
    icon: 'droplet',
    title: 'Lubricants',
    lead: 'Engine oils and specialty lubricants for fleets, workshops and resellers.',
    body: 'Keeping engines and drivetrains protected calls for the right lubricant, correctly specified. We source engine oils, transmission fluids and specialty lubricants formulated to recognised OEM and industry standards, supplied in packaging suited to retail and workshop use across European markets.',
    features: [
      'Engine oils across common viscosity grades',
      'Transmission & specialty lubricants',
      'Formulated to recognised OEM / industry specs',
      'Retail and workshop pack formats',
    ],
  },
  {
    id: 'parts',
    icon: 'gear',
    title: 'Spare Parts',
    lead: 'Automotive consumables and replacement parts, sourced to demand.',
    body: 'Beyond batteries and lubricants, we source a growing catalogue of automotive spare parts and consumables. Tell us what your market needs and we will match it to a manufacturer that meets the right quality and price — consolidating supply so you deal with a single, reliable partner.',
    features: [
      'Consumables and replacement parts',
      'Sourced to match your market demand',
      'Quality matched to specification and budget',
      'Consolidated supply from one partner',
    ],
  },
];
---
<Layout title="Products & Services" path="/products" description="SLI batteries, lubricants and automotive spare parts — sourced from trusted manufacturers and supplied across Europe by Comstrat Industrial Ltd.">
  <Hero compact>
    <div class="max-w-3xl">
      <Reveal><span class="eyebrow-dark">Products & Services</span></Reveal>
      <Reveal delay={80}>
        <h1 class="mt-4 font-display text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
          Everything that keeps vehicles moving
        </h1>
      </Reveal>
      <Reveal delay={160}>
        <p class="mt-6 text-lg leading-relaxed text-slatey-300">
          Three core product lines, each sourced from trusted manufacturers, quality-checked and
          delivered reliably to European markets.
        </p>
      </Reveal>
      <Reveal delay={240}>
        <div class="mt-8 flex flex-wrap gap-2">
          {categories.map((c) => (
            <a href={`#${c.id}`} class="rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white transition-colors hover:border-brand-400 hover:text-brand-300">
              {c.title}
            </a>
          ))}
        </div>
      </Reveal>
    </div>
  </Hero>

  <section class="bg-white py-20 sm:py-28">
    <div class="container-x space-y-20 sm:space-y-28">
      {categories.map((c, i) => (
        <div id={c.id} class="scroll-mt-28 grid items-center gap-10 lg:grid-cols-12 lg:gap-16">
          <Reveal class:list={['lg:col-span-6', i % 2 === 1 ? 'lg:order-2' : '']}>
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-50 text-brand-600 ring-1 ring-brand-100">
              <Icon name={c.icon} class="h-7 w-7" />
            </span>
            <h2 class="mt-6 font-display text-3xl font-bold tracking-tight text-ink-900">{c.title}</h2>
            <p class="mt-3 text-lg font-medium text-slatey-700">{c.lead}</p>
            <p class="mt-4 text-base leading-relaxed text-slatey-600">{c.body}</p>
          </Reveal>
          <Reveal delay={120} class:list={['lg:col-span-6', i % 2 === 1 ? 'lg:order-1' : '']}>
            <div class="rounded-3xl border border-slatey-200 bg-slatey-50 p-8 shadow-card">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-slatey-500">Highlights</h3>
              <ul class="mt-5 space-y-3.5">
                {c.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-brand-500 text-white">
                      <Icon name="check" class="h-3.5 w-3.5" />
                    </span>
                    <span class="text-sm leading-relaxed text-slatey-700">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Reveal>
        </div>
      ))}
    </div>
  </section>

  <!-- NOTE: product photography placeholders — drop real imagery into the
       category blocks above (replace the "Highlights" panel or add an <img>). -->

  <CtaBand
    title="Need something specific?"
    text="Send us your specifications, volumes and target market. We will source it and come back with a competitive proposal."
  />
</Layout>
