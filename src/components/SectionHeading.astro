---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
  dark?: boolean;
  class?: string;
}
const { eyebrow, title, intro, align = 'center', dark = false, class: className = '' } = Astro.props;
const alignClass = align === 'center' ? 'mx-auto text-center items-center' : 'items-start text-left';
const titleColor = dark ? 'text-white' : 'text-ink-900';
const introColor = dark ? 'text-slatey-300' : 'text-slatey-600';
---
<div class={`flex max-w-2xl flex-col gap-4 ${alignClass} ${className}`}>
  {eyebrow && <span class={dark ? 'eyebrow-dark' : 'eyebrow'}>{eyebrow}</span>}
  <h2 class={`font-display text-3xl font-bold leading-tight tracking-tight sm:text-4xl ${titleColor}`}>
    {title}
  </h2>
  {intro && <p class={`text-base leading-relaxed sm:text-lg ${introColor}`}>{intro}</p>}
</div>
