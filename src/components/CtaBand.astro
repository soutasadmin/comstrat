---
import Icon from './Icon.astro';
import Reveal from './Reveal.astro';
import { site } from '../data/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Let's talk supply.",
  text = 'Tell us what you need and the markets you serve. We will put together a competitive, reliable sourcing proposal.',
} = Astro.props;
---
<section class="bg-white py-20 sm:py-24">
  <div class="container-x">
    <Reveal class="relative overflow-hidden rounded-3xl bg-ink-900 px-6 py-14 sm:px-14 sm:py-16">
      <div class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-brand-500/25 blur-[100px]"></div>
      <div class="pointer-events-none absolute inset-0 bg-grid-dark [background-size:48px_48px] opacity-50"></div>
      <div class="relative flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center">
        <div class="max-w-xl">
          <span class="eyebrow-dark">Get in touch</span>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h2>
          <p class="mt-4 text-base leading-relaxed text-slatey-300">{text}</p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="btn-primary">
            Contact us <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href={`mailto:${site.email}`} class="btn-ghost-light">
            <Icon name="mail" class="h-4 w-4" /> {site.email}
          </a>
        </div>
      </div>
    </Reveal>
  </div>
</section>
