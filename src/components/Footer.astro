---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="bg-ink-950 text-slatey-300">
  <div class="container-x py-16">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <Logo variant="light" />
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-slatey-400">
          {site.tagline}
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {site.sourcing.map((c) => (
            <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slatey-300">{c}</span>
          ))}
        </div>
      </div>

      <div class="md:col-span-3">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/70">Explore</h3>
        <ul class="mt-4 space-y-3 text-sm">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="text-slatey-400 transition-colors hover:text-brand-400">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/70">Get in touch</h3>
        <ul class="mt-4 space-y-4 text-sm">
          <li class="flex gap-3">
            <Icon name="pin" class="mt-0.5 h-5 w-5 shrink-0 text-brand-400" />
            <span class="text-slatey-400">
              {site.address.line1}<br />{site.address.line2}<br />{site.address.city}
            </span>
          </li>
          <li class="flex gap-3">
            <Icon name="mail" class="h-5 w-5 shrink-0 text-brand-400" />
            <a href={`mailto:${site.email}`} class="text-slatey-400 transition-colors hover:text-brand-400">{site.email}</a>
          </li>
          <li class="flex gap-3">
            <Icon name="phone" class="h-5 w-5 shrink-0 text-brand-400" />
            <a href={`tel:${site.phoneHref}`} class="text-slatey-400 transition-colors hover:text-brand-400">{site.phone}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-6 text-xs text-slatey-500 sm:flex-row sm:items-center">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Hong Kong · Sourcing worldwide · Serving Europe</p>
    </div>
  </div>
</footer>
