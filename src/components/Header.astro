---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { nav } from '../data/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-state="top"
>
  <div class="container-x">
    <div
      id="header-bar"
      class="mt-3 flex items-center justify-between rounded-full border border-white/10 bg-ink-900/60 px-4 py-2.5 backdrop-blur-md transition-all duration-300 sm:px-5"
    >
      <Logo variant="light" />

      <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'text-white'
                  : 'text-white/65 hover:text-white',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <a href="/contact" class="hidden btn-primary !px-5 !py-2.5 sm:inline-flex">
          Get a quote
        </a>
        <button
          id="menu-toggle"
          type="button"
          class="grid h-10 w-10 place-items-center rounded-full border border-white/15 text-white md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="container-x hidden md:hidden"
  >
    <div class="mt-2 rounded-3xl border border-white/10 bg-ink-900/95 p-4 backdrop-blur-md">
      <nav class="flex flex-col" aria-label="Mobile">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-2xl px-4 py-3 text-base font-medium transition-colors',
                isActive(item.href) ? 'bg-white/10 text-white' : 'text-white/75 hover:bg-white/5 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a href="/contact" class="btn-primary mt-3 w-full">Get a quote</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const bar = document.getElementById('header-bar');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  // Solidify bar on scroll
  const onScroll = () => {
    if (!bar) return;
    if (window.scrollY > 16) {
      bar.classList.add('!bg-ink-950/90', 'shadow-[0_8px_30px_rgba(0,0,0,0.35)]');
      header?.setAttribute('data-state', 'scrolled');
    } else {
      bar.classList.remove('!bg-ink-950/90', 'shadow-[0_8px_30px_rgba(0,0,0,0.35)]');
      header?.setAttribute('data-state', 'top');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
