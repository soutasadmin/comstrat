---
// Wordmark logo (placeholder — swap for a real asset when available).
import { url } from '../data/site';
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const text = variant === 'light' ? 'text-white' : 'text-ink-900';
const sub = variant === 'light' ? 'text-white/55' : 'text-slatey-500';
---
<a href={url('/')} class={`group inline-flex items-center gap-2.5 ${className}`} aria-label="Comstrat — home">
  <img src={url('/comstrat.png')} alt="" aria-hidden="true" class="h-9 w-9 transition-transform group-hover:scale-105" />
  <span class="leading-none">
    <span class={`block font-display text-lg font-extrabold tracking-tight ${text}`}>COMSTRAT</span>
    <span class={`block text-[10px] font-medium uppercase tracking-[0.22em] ${sub}`}>Industrial Ltd</span>
  </span>
</a>
